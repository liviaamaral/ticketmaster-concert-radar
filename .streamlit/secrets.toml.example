[snowflake]
account   = "your_account_identifier"   # e.g. "abc12345.us-east-1"
user      = "your_username"
role      = "ACCOUNTADMIN"
warehouse = "TICKETMASTER_WH"
database  = "TICKETMASTER"

# Recommended: base64-encoded DER — single line, no headers, no newlines.
# Generate with:
#   openssl pkcs8 -topk8 -inform PEM -outform DER -in ~/.ssh/snowflake_key.p8 -nocrypt \
#     | base64 | tr -d '\n'
private_key = "MIIEpAIBAAKCAQEA..."
